# Node
node_modules/
npm-debug.log*
package-lock.json

# Local state / scratch
**/announcer.json
discord/announcer.json
web/_shots.mjs
*.tmp

# OS
.DS_Store

# Map packs (large; provided by the user at runtime)
server/maps/*.pk3
# fetch-maps.sh working files (lock, failure list, in-flight temps)
server/maps/.fetch-*
server/maps/.part-*

# Server-written race records / finish-event log (runtime data; the collector
# ships them into the stats DB)
server/topscores/**
server/racelog/**
!server/topscores/.gitkeep
!server/racelog/.gitkeep

# SQLite runtime journals
data/*.sqlite-wal
data/*.sqlite-shm
*.sqlite-wal
*.sqlite-shm
.env
backups/

# Generated WR-ghost viewer meshes (converted on the box, mounted into web)
web/public/maps/*.glb

# Local scratch (screenshots, large paks deployed out-of-band)
temp/
