# Copy to .env and fill in. docker compose reads this automatically.

# --- Central stats site (docker-compose.yml) --------------------------------
# Optional shared ingest secret. Prefer per-server tokens instead (see AGENT.md
# / `node admin.js enroll`). Generate with: openssl rand -hex 32
INGEST_TOKEN=

# Name shown for records ingested by the co-located collector.
SERVER_NAME=local

# Discord webhook for the record announcer (leave empty for dry-run/log mode).
DISCORD_WEBHOOK_URL=

# --- Remote game-server agent (docker-compose.agent.yml) --------------------
# The central site's public ingest endpoint (use https:// across the internet).
INGEST_URL=https://stats.example.com/api/ingest
# The per-server token you were given by the central admin (openssl rand / enroll).
# INGEST_TOKEN=...
# A friendly name for your server, shown on the stats site.
# SERVER_NAME=My Race Server

# --- Game server (server/docker-compose.yml; put these in server/.env) ------
# Remote console password. Empty disables rcon. The stats site's admin panel
# uses this to broadcast maintenance notices / run the RCON console — register
# it there per server with: docker compose exec web node admin.js rcon <id> <pw>
# RCON_PASSWORD=
# Ship the game console to the stats site's admin log view (needs INGEST_URL +
# INGEST_TOKEN). 1 = on (default), 0 = off. Batching cadence is tunable with
# LOG_FLUSH_SECS (default 5) and LOG_BATCH_LINES (default 100).
# LOG_SHIP=1
# Optional HTTP pak mirror for fast client downloads (start the pakserver:
# `docker compose --profile httpdl up -d` in server/). Must be a URL that game
# CLIENTS can reach — leave empty to use UDP transfer over the game port.
# SV_UPLOADS_BASEURL=http://your-host-or-ip:44445
# PAK_HTTP_PORT=44445
